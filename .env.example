# Copy this file to .env and fill in your values

# From your Slack App settings → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...        # Bot User OAuth Token
SLACK_USER_TOKEN=xoxp-...       # User OAuth Token (needed for search + ingest)

# From your Slack App settings → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=...

# From platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# From app.pinecone.io → API Keys
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=slack-knowledge

# Port the server listens on (Railway/Render set this automatically)
PORT=3000
